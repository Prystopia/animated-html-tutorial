{
  "name": "animated-tutorial",
  "version": "0.2.0",
  "description": "HTML5 canvas-based animated tutorials and help documentation for any web app",
  "keywords": [
    "tutorial",
    "onboarding",
    "canvas",
    "html5",
    "walkthrough"
  ],
  "homepage": "https://github.com/Prystopia/animated-html-tutorial#readme",
  "bugs": {
    "url": "https://github.com/Prystopia/animated-html-tutorial/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Prystopia/animated-html-tutorial.git"
  },
  "files": [
    "dist/src/animated-tutorial.js",
    "dist/src/animated-tutorial.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/animated-tutorial.d.ts",
      "import": "./dist/src/animated-tutorial.js",
      "require": "./dist/src/animated-tutorial.js"
    }
  },
  "license": "MIT",
  "author": "prystopia",
  "type": "commonjs",
  "main": "dist/src/animated-tutorial.js",
  "types": "dist/src/animated-tutorial.d.ts",
  "scripts": {
    "build-prod": "tsc -p src/tsconfig.json && esbuild src/animated-tutorial.ts --bundle --minify --keep-names --format=cjs --outfile=dist/src/animated-tutorial.js && esbuild src/browser-entry.ts --bundle --minify --keep-names --format=iife --outfile=dist/animated-tutorial.js",
    "build-dev": "tsc -p src/tsconfig.dev.json"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
